---
import { type CollectionEntry, getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import ContactCTA from '../../components/ContactCTA.astro';
import Pill from '../../components/Pill.astro';
import { render } from 'astro:content';

interface Props {
	entry: CollectionEntry<'work'>;
}

export async function getStaticPaths() {
	const work = await getCollection('work');
	return work.map((entry) => ({
		params: { slug: entry.id },
		props: { entry },
	}));
}

const { entry } = Astro.props;
const { Content } = await render(entry);
---

<BaseLayout title={entry.data.title} description={entry.data.description}>
	<main class="wrapper">
		<article>
			<header class="article-header">
				<a class="back-link" href="/work/">
					<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="19" y1="12" x2="5" y2="12"/><polyline points="12 19 5 12 12 5"/></svg>
					All work
				</a>
				<h1>{entry.data.title}</h1>
				<p class="description">{entry.data.description}</p>
				<div class="tags">
					{entry.data.tags.map((t) => <Pill>{t}</Pill>)}
				</div>
				{(entry.data.repo || entry.data.demo) && (
					<div class="links">
						{entry.data.repo && (
							<a href={entry.data.repo} target="_blank" rel="noopener" class="ext-link">GitHub</a>
						)}
						{entry.data.demo && (
							<a href={entry.data.demo} target="_blank" rel="noopener" class="ext-link">Demo</a>
						)}
					</div>
				)}
			</header>

			{entry.data.gallery && entry.data.gallery.length > 1 ? (
				<div class="gallery">
					{entry.data.gallery.map((img) => (
						<img src={img} alt={entry.data.img_alt || ''} loading="lazy" class="gallery-image" />
					))}
				</div>
			) : (
				entry.data.img && <img src={entry.data.img} alt={entry.data.img_alt || ''} loading="lazy" class="hero-image" />
			)}

			<div class="prose">
				<Content />
			</div>

			{entry.data.video && (
				<div class="videos">
					{entry.data.video.map((url) => (
						<iframe
							src={url}
							width="100%"
							height="400"
							frameborder="0"
							allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
							allowfullscreen
							loading="lazy"
						></iframe>
					))}
				</div>
			)}
		</article>

		<ContactCTA />
	</main>
</BaseLayout>

<style>
	main {
		display: flex;
		flex-direction: column;
		gap: 3rem;
		padding-top: 3rem;
		padding-bottom: 0;
	}

	article {
		display: flex;
		flex-direction: column;
		gap: 2.5rem;
		max-width: 48rem;
	}

	.article-header {
		display: flex;
		flex-direction: column;
		gap: 1rem;
	}

	.back-link {
		display: inline-flex;
		align-items: center;
		gap: 0.375rem;
		font-size: var(--text-sm);
		color: var(--gray-400);
		transition: color var(--transition);
		width: fit-content;
	}

	.back-link:hover {
		color: var(--gray-0);
	}

	h1 {
		font-size: var(--text-3xl);
	}

	.description {
		font-size: var(--text-md);
		color: var(--gray-400);
		line-height: 1.6;
		max-width: 54ch;
	}

	.tags {
		display: flex;
		flex-wrap: wrap;
		gap: 0.375rem;
	}

	.links {
		display: flex;
		gap: 1rem;
	}

	.ext-link {
		font-size: var(--text-sm);
		font-weight: 500;
		color: var(--gray-0);
		padding: 0.5rem 1rem;
		border: 1px solid var(--gray-800);
		border-radius: var(--radius-full);
		transition: background var(--transition), border-color var(--transition);
	}

	.ext-link:hover {
		background: var(--accent-subtle);
		border-color: var(--gray-700);
	}

	.hero-image {
		width: 100%;
		border-radius: var(--radius-lg);
		border: 1px solid var(--gray-800);
	}

	.gallery {
		display: grid;
		gap: 1rem;
		grid-template-columns: 1fr;
	}

	@media (min-width: 40em) {
		.gallery {
			grid-template-columns: 1fr 1fr;
		}
	}

	.gallery-image {
		width: 100%;
		border-radius: var(--radius-lg);
		border: 1px solid var(--gray-800);
	}

	.prose {
		font-size: var(--text-base);
		line-height: 1.7;
		color: var(--gray-300);
	}

	.prose :global(* + *) {
		margin-top: 1rem;
	}

	.prose :global(h1),
	.prose :global(h2) {
		font-size: var(--text-xl);
		margin: 2rem 0 1rem;
		color: var(--gray-0);
	}

	.prose :global(h3),
	.prose :global(h4) {
		font-size: var(--text-lg);
		margin: 1.5rem 0 0.75rem;
		color: var(--gray-0);
	}

	.prose :global(strong) {
		color: var(--gray-0);
	}

	.prose :global(a) {
		color: var(--gray-0);
		text-decoration: underline;
		text-underline-offset: 0.2em;
	}

	.prose :global(blockquote) {
		padding-left: 1rem;
		border-left: 2px solid var(--gray-700);
		color: var(--gray-300);
		font-style: italic;
	}

	.prose :global(img) {
		border-radius: var(--radius-lg);
		border: 1px solid var(--gray-800);
	}

	.videos {
		display: flex;
		flex-direction: column;
		gap: 1.5rem;
	}

	iframe {
		border-radius: var(--radius-lg);
		border: 1px solid var(--gray-800);
	}

	@media (min-width: 50em) {
		h1 {
			font-size: var(--text-4xl);
		}
	}
</style>
