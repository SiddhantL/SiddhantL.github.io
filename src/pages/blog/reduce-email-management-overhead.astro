		color: var(--gray-0);
		margin-bottom: 1rem;
	}
	
	.cta-section p {
		color: var(--gray-100);
		margin-bottom: 1.5rem;
	}
	
	@media (min-width: 50em) {
		.post-header h1 {
			font-size: var(--text-4xl);
		}
		
		.blog-post {
			padding: 3rem 2rem;
		}
