---
import { type CollectionEntry, getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import ContactCTA from '../../components/ContactCTA.astro';
import { render } from 'astro:content';

interface Props {
	entry: CollectionEntry<'blog'>;
}

export async function getStaticPaths() {
	const posts = await getCollection('blog');
	return posts.map((entry) => ({
		params: { slug: entry.id },
		props: { entry },
	}));
}

const { entry } = Astro.props;
const { Content } = await render(entry);

const oaths = [
	"Typed by a human. Spell-checked by a robot. All opinions, bad takes, and typos that survived are 100% organic, free-range, grass-fed me.",
	"A real person wrote this. An AI fixed my grammar. We both agreed not to talk about the first draft.",
	"Written by me. Formatted by a machine. The machine wanted credit but I said no.",
	"No LLMs were harmed in the making of this post. One was mildly inconvenienced during proofreading.",
	"The thoughts are mine. The commas are Claude's. The accountability is... let's not go there.",
	"Human-generated content. AI-assisted punctuation. The ratio of effort is embarrassing.",
	"I wrote every word. A robot fixed every other word. We are not the same.",
	"This post passed the Turing test. Mostly because the Turing test has low standards.",
	"Authentically written by a guy who could have had AI write it in 4 seconds but chose to suffer instead.",
	"My brain, my keyboard, my bad jokes. AI just made sure I didn't publish the word 'teh' fourteen times.",
];
const oath = oaths[Math.floor(Math.random() * oaths.length)];
---

<BaseLayout title={entry.data.title} description={entry.data.description}>
	<main class="wrapper">
		<article>
			<header class="article-header">
				<a class="back-link" href="/blog/">
					<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="19" y1="12" x2="5" y2="12"/><polyline points="12 19 5 12 12 5"/></svg>
					All posts
				</a>
				<time datetime={entry.data.publishDate.toISOString()}>
					{entry.data.publishDate.toLocaleDateString('en-US', {
						year: 'numeric',
						month: 'long',
						day: 'numeric',
						timeZone: 'UTC',
					})}
				</time>
				<h1>{entry.data.title}</h1>
				<p class="description">{entry.data.description}</p>
				{entry.data.tags && entry.data.tags.length > 0 && (
					<div class="tags">
						{entry.data.tags.map(tag => <span class="tag">{tag}</span>)}
					</div>
				)}
			</header>

			<div class="prose">
				<Content />
			</div>

			<div class="oath">
				<span class="oath-icon">*</span>
				<p>{oath}</p>
			</div>
		</article>

		<ContactCTA />
	</main>
</BaseLayout>

<style>
	main {
		display: flex;
		flex-direction: column;
		gap: 3rem;
		padding-top: 3rem;
		padding-bottom: 0;
	}

	article {
		display: flex;
		flex-direction: column;
		gap: 2.5rem;
		max-width: 40rem;
	}

	.article-header {
		display: flex;
		flex-direction: column;
		gap: 0.75rem;
	}

	.back-link {
		display: inline-flex;
		align-items: center;
		gap: 0.375rem;
		font-size: var(--text-sm);
		color: var(--gray-400);
		transition: color var(--transition);
		width: fit-content;
		margin-bottom: 0.5rem;
	}

	.back-link:hover {
		color: var(--gray-0);
	}

	time {
		font-size: var(--text-sm);
		color: var(--gray-500);
	}

	h1 {
		font-size: var(--text-3xl);
	}

	.description {
		font-size: var(--text-md);
		color: var(--gray-400);
		line-height: 1.6;
	}

	.tags {
		display: flex;
		flex-wrap: wrap;
		gap: 0.375rem;
	}

	.tag {
		font-size: var(--text-xs);
		padding: 0.2rem 0.5rem;
		border-radius: var(--radius-full);
		background: var(--accent-subtle);
		color: var(--gray-400);
		font-weight: 500;
	}

	.prose {
		font-size: var(--text-base);
		line-height: 1.8;
		color: var(--gray-300);
	}

	.prose :global(* + *) {
		margin-top: 1.25rem;
	}

	.prose :global(h2) {
		font-size: var(--text-xl);
		margin: 2.5rem 0 1rem;
		color: var(--gray-0);
	}

	.prose :global(h3) {
		font-size: var(--text-lg);
		margin: 2rem 0 0.75rem;
		color: var(--gray-0);
	}

	.prose :global(strong) {
		color: var(--gray-0);
	}

	.prose :global(a) {
		color: var(--gray-0);
		text-decoration: underline;
		text-underline-offset: 0.2em;
	}

	.prose :global(blockquote) {
		padding-left: 1rem;
		border-left: 2px solid var(--gray-700);
		color: var(--gray-400);
		font-style: italic;
	}

	.prose :global(code) {
		font-size: 0.9em;
		padding: 0.15em 0.35em;
		background: var(--accent-subtle);
		border-radius: 4px;
	}

	.prose :global(pre) {
		padding: 1rem 1.25rem;
		border-radius: var(--radius-md);
		background: var(--accent-subtle);
		overflow-x: auto;
		font-size: var(--text-sm);
		line-height: 1.6;
	}

	.prose :global(pre code) {
		padding: 0;
		background: none;
	}

	.prose :global(img) {
		border-radius: var(--radius-lg);
		border: 1px solid var(--gray-800);
	}

	.prose :global(ul), .prose :global(ol) {
		padding-left: 1.5rem;
	}

	.prose :global(li) {
		margin-bottom: 0.5rem;
	}

	.oath {
		display: flex;
		align-items: flex-start;
		gap: 0.5rem;
		padding: 1rem 1.25rem;
		border: 1px dashed var(--gray-800);
		border-radius: var(--radius-md);
		opacity: 0;
		animation: fade-oath 0.6s ease forwards;
		animation-delay: 2s;
	}

	.oath-icon {
		font-size: var(--text-lg);
		line-height: 1;
		color: var(--gray-500);
		flex-shrink: 0;
		animation: pulse 3s ease-in-out infinite;
	}

	.oath p {
		font-size: var(--text-xs);
		color: var(--gray-500);
		line-height: 1.5;
		font-style: italic;
	}

	@keyframes fade-oath {
		from { opacity: 0; transform: translateY(4px); }
		to { opacity: 1; transform: translateY(0); }
	}

	@keyframes pulse {
		0%, 100% { opacity: 0.4; }
		50% { opacity: 1; }
	}

	@media (min-width: 50em) {
		h1 {
			font-size: var(--text-4xl);
		}
	}
</style>
