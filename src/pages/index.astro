---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import PortfolioPreview from '../components/PortfolioPreview.astro';
import ContactCTA from '../components/ContactCTA.astro';

const allProjects = (await getCollection('work')).filter((entry) => !entry.id.includes('/') && !entry.data.hidden);
const featuredSlugs = ['minro', 'iris', 'safe-distancing', 'sensord'];
const projects = featuredSlugs
	.map(slug => allProjects.find(p => p.slug === slug || p.id === `${slug}.md` || p.id === slug))
	.filter(Boolean);
---

<BaseLayout>
	<main>
		<section class="hero-section wrapper">
			<div class="intro">
				<h1>Siddhant Lad</h1>
				<p class="tagline">Building <a href="https://minro.com" target="_blank" rel="noopener">Minro</a> (YC F25). We know which users you're about to lose. You'll hear about us.</p>
				<div class="social-links">
					<a href="https://github.com/SiddhantL" target="_blank" rel="noopener" aria-label="GitHub">
						<svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor"><path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/></svg>
					</a>
					<a href="https://www.linkedin.com/in/sidlad" target="_blank" rel="noopener" aria-label="LinkedIn">
						<svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>
					</a>
					<a href="https://www.youtube.com/@siddhantlad" target="_blank" rel="noopener" aria-label="YouTube">
						<svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor"><path d="M23.498 6.186a3.016 3.016 0 0 0-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.017 3.017 0 0 0 .502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a3.016 3.016 0 0 0 2.122 2.136c1.871.505 9.376.505 9.376.505s7.505 0 9.377-.505a3.015 3.015 0 0 0 2.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814zM9.545 15.568V8.432L15.818 12l-6.273 3.568z"/></svg>
					</a>
					<a href="mailto:siddhantnlad@gmail.com" aria-label="Email">
						<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="4" width="20" height="16" rx="2"/><path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/></svg>
					</a>
				</div>
			</div>
			<div class="portrait-wrapper">
				<img
					src="/assets/portrait.jpg"
					alt="Siddhant Lad"
					width="280"
					height="350"
					class="portrait"
				/>
			</div>
		</section>

		<section class="projects-section wrapper">
			<div class="section-header">
				<h2>Selected work</h2>
				<a href="/work/" class="view-all">
					View all
					<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
				</a>
			</div>
			<div class="projects-grid">
				{projects.map((project) => (
					<PortfolioPreview project={project} />
				))}
			</div>
		</section>

		<section class="skills-section wrapper">
			<h2>What I do</h2>
			<div class="skills-grid">
				<div class="skill-card">
					<div class="skill-icon">
						<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="16 18 22 12 16 6"/><polyline points="8 6 2 12 8 18"/></svg>
					</div>
					<h3>Full Stack Engineering</h3>
					<p>Building scalable web, mobile, and backend systems with clean architecture and fast iteration.</p>
				</div>
				<div class="skill-card">
					<div class="skill-icon">
						<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2L2 7l10 5 10-5-10-5z"/><path d="M2 17l10 5 10-5"/><path d="M2 12l10 5 10-5"/></svg>
					</div>
					<h3>Machine Learning</h3>
					<p>Designing models that turn data into decisions, from deep learning to control-aware neural networks.</p>
				</div>
				<div class="skill-card">
					<div class="skill-icon">
						<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="3" width="20" height="14" rx="2"/><line x1="8" y1="21" x2="16" y2="21"/><line x1="12" y1="17" x2="12" y2="21"/></svg>
					</div>
					<h3>Systems Design</h3>
					<p>Engineering robust, real-world systems by integrating software, hardware, and intelligence.</p>
				</div>
			</div>
		</section>

		<ContactCTA />
	</main>
</BaseLayout>

<style>
	main {
		display: flex;
		flex-direction: column;
		gap: 5rem;
		padding-bottom: 0;
	}

	/* Hero */
	.hero-section {
		display: flex;
		flex-direction: column-reverse;
		align-items: center;
		gap: 2.5rem;
		padding-top: 4rem;
	}

	.intro {
		text-align: center;
	}

	.intro h1 {
		font-size: var(--text-4xl);
		margin-bottom: 1rem;
	}

	.tagline {
		font-size: var(--text-md);
		color: var(--gray-400);
		max-width: 42ch;
		line-height: 1.6;
		margin: 0 auto 1.5rem;
	}

	.tagline :global(a) {
		color: var(--gray-0);
		text-decoration: underline;
		text-underline-offset: 0.2em;
		text-decoration-color: var(--gray-700);
		transition: text-decoration-color var(--transition);
	}

	.tagline :global(a:hover) {
		text-decoration-color: var(--gray-0);
	}

	.social-links {
		display: flex;
		justify-content: center;
		gap: 1rem;
	}

	.social-links a {
		display: flex;
		align-items: center;
		justify-content: center;
		width: 2.5rem;
		height: 2.5rem;
		border-radius: var(--radius-full);
		color: var(--gray-400);
		transition: color var(--transition);
	}

	.social-links a:hover {
		color: var(--gray-0);
	}

	.portrait-wrapper {
		flex-shrink: 0;
	}

	.portrait {
		width: 160px;
		height: 160px;
		border-radius: var(--radius-full);
		object-fit: cover;
		border: 2px solid var(--gray-800);
	}

	@media (min-width: 50em) {
		.hero-section {
			flex-direction: row;
			justify-content: space-between;
			padding-top: 6rem;
		}

		.intro {
			text-align: left;
		}

		.intro h1 {
			font-size: var(--text-5xl);
		}

		.tagline {
			margin: 0 0 1.5rem;
			font-size: var(--text-lg);
		}

		.social-links {
			justify-content: flex-start;
		}

		.portrait {
			width: 200px;
			height: 200px;
		}
	}

	/* Projects */
	.projects-section {
		display: flex;
		flex-direction: column;
		gap: 2rem;
	}

	.section-header {
		display: flex;
		align-items: baseline;
		justify-content: space-between;
	}

	.section-header h2 {
		font-size: var(--text-2xl);
	}

	.view-all {
		display: inline-flex;
		align-items: center;
		gap: 0.375rem;
		font-size: var(--text-sm);
		color: var(--gray-400);
		transition: color var(--transition);
	}

	.view-all:hover {
		color: var(--gray-0);
	}

	.projects-grid {
		display: grid;
		gap: 1.5rem;
		grid-template-columns: 1fr;
	}

	@media (min-width: 40em) {
		.projects-grid {
			grid-template-columns: 1fr 1fr;
		}
	}

	/* Skills */
	.skills-section {
		display: flex;
		flex-direction: column;
		gap: 2rem;
	}

	.skills-section h2 {
		font-size: var(--text-2xl);
	}

	.skills-grid {
		display: grid;
		gap: 1.5rem;
		grid-template-columns: 1fr;
	}

	@media (min-width: 40em) {
		.skills-grid {
			grid-template-columns: repeat(3, 1fr);
		}
	}

	.skill-card {
		padding: 1.5rem;
		border: 1px solid var(--gray-800);
		border-radius: var(--radius-lg);
		transition: border-color var(--transition);
	}

	.skill-card:hover {
		border-color: var(--gray-700);
	}

	.skill-icon {
		display: flex;
		align-items: center;
		justify-content: center;
		width: 2.5rem;
		height: 2.5rem;
		border-radius: var(--radius-md);
		background: var(--accent-subtle);
		color: var(--gray-300);
		margin-bottom: 1rem;
	}

	.skill-card h3 {
		font-size: var(--text-base);
		font-weight: 600;
		margin-bottom: 0.5rem;
	}

	.skill-card p {
		font-size: var(--text-sm);
		color: var(--gray-400);
		line-height: 1.6;
	}
</style>
