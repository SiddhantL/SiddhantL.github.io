---
import { getCollection } from 'astro:content';
import SkillSection from '../components/SkillSection.astro';
import BaseLayout from '../layouts/BaseLayout.astro';

import CallToAction from '../components/CallToAction.astro';
import Grid from '../components/Grid.astro';
import Hero from '../components/Hero.astro';
import Icon from '../components/Icon.astro';
import Pill from '../components/Pill.astro';
import PortfolioPreview from '../components/PortfolioPreview.astro';
import ContactCTA from '../components/ContactCTA.astro';
import Skills from '../components/Skills.astro';

// Manually select featured projects in desired order
const allProjects = (await getCollection('work')).filter((entry) => !entry.id.includes('/'));
const featuredSlugs = ['iris', 'safe-distancing', 'workspace', 'sensord'];
const projects = featuredSlugs
	.map(slug => allProjects.find(p => p.slug === slug || p.id === `${slug}.md` || p.id === slug))
	.filter(Boolean);
---

<BaseLayout 
	title="Minro - AI Calendar Assistant | Automate Your Schedule & Email Management" 
	description="Transform your productivity with Minro's AI calendar assistant. Automate scheduling, email replies, and time management through natural language commands. Start your free trial."
>
	<!-- JSON-LD Structured Data -->
	<script type="application/ld+json">
	{
		"@context": "https://schema.org",
		"@type": "Organization",
		"name": "Minro",
		"description": "AI-powered calendar assistant that automates scheduling and email management for busy professionals.",
		"url": "https://minro.com",
		"logo": "https://minro.com/assets/iris-logo-icon.png",
		"foundingDate": "2025",
		"sameAs": [
			"https://www.ycombinator.com/launches/Omf-iris-the-personal-assistant"
		],
		"contactPoint": {
			"@type": "ContactPoint",
			"contactType": "Customer Support",
			"email": "hello@minro.com"
		}
	}
	</script>

	<div class="stack gap-20 lg:gap-48">
		<div class="wrapper stack gap-8 lg:gap-20">
			<header class="hero">
				<Hero
					title="AI Calendar Assistant That Actually Works"
					tagline="Automate scheduling, email management, and time blocking with natural language commands. Backed by Y Combinator."
					align="start"
				>
					<div class="roles">
						<Pill><Icon icon="calendar" size="1.33em" /> Smart Scheduling</Pill>
						<Pill><Icon icon="email" size="1.33em" /> Email Automation</Pill>
						<Pill><Icon icon="chat" size="1.33em" /> Natural Language</Pill>
					</div>
				</Hero>

				<img
					alt="Minro AI Calendar Assistant Interface"
					width="480"
					height="620"
					src="/assets/yc-photo.png"
					title="Minro - Y Combinator Backed AI Calendar Assistant"
				/>
			</header>

			<!-- Answer Capsule for AI Citation -->
			<section class="answer-capsule">
				<h2>What is Minro?</h2>
				<p>Minro is an AI-powered calendar assistant that automates scheduling, email management, and time blocking through natural language commands, helping busy professionals save 5+ hours weekly on administrative tasks.</p>
			</section>

			<Skills />
		</div>

		<main class="wrapper stack gap-20 lg:gap-48">
			<section class="section with-background with-cta">
				<header class="section-header stack gap-2 lg:gap-4">
					<h3>How Minro Works</h3>
					<p>Simply tell Minro what you need in natural language, and it handles the rest — from reorganizing your day to managing email replies automatically.</p>
				</header>

				<div class="gallery">
					<Grid variant="offset">
						{
							projects.map((project) => (
								<li>
									<PortfolioPreview project={project} />
								</li>
							))
						}
					</Grid>
				</div>

				<div class="cta">
					<CallToAction href="/work/">
						View All
						<Icon icon="arrow-right" size="1.2em" />
					</CallToAction>
				</div>
			</section>

			<!-- ✅ Replaced Mentions with Skills -->
			<SkillSection />
		</main>

		<!-- Blog Preview Section -->
		<section class="section with-background blog-preview">
			<header class="section-header stack gap-2 lg:gap-4">
				<h3>AI Calendar Insights</h3>
				<p>Learn how to optimize your calendar workflow with AI-powered automation strategies and productivity tips from our team.</p>
			</header>

			<div class="blog-cards">
				<article class="blog-card">
					<h4><a href="/blog/how-to-automate-calendar-management/">How to Automate Calendar Management</a></h4>
					<p>Save 5+ hours weekly with proven calendar automation strategies that eliminate manual scheduling overhead.</p>
				</article>
				<article class="blog-card">
					<h4><a href="/blog/best-ai-calendar-assistants-2026/">Best AI Calendar Assistants 2026</a></h4>
					<p>Compare top AI calendar tools and find the perfect automation solution for your productivity workflow.</p>
				</article>
				<article class="blog-card">
					<h4><a href="/blog/reduce-email-management-overhead/">Reduce Email Management Overhead</a></h4>
					<p>Cut email time by 70% with AI-powered response automation and intelligent coordination strategies.</p>
				</article>
			</div>

			<div class="cta">
				<CallToAction href="/blog/">
					View All Posts
					<Icon icon="arrow-right" size="1.2em" />
				</CallToAction>
			</div>
		</section>

		<ContactCTA />
	</div>
</BaseLayout>

<style>
	.hero {
		display: flex;
		flex-direction: column;
		align-items: center;
		gap: 2rem;
	}

	.roles {
		display: none;
	}

	.hero img {
		aspect-ratio: 5 / 4;
		object-fit: cover;
		object-position: center;
		border-radius: 1.5rem;
		box-shadow: var(--shadow-md);
	}

	@media (min-width: 50em) {
		.hero {
			display: grid;
			grid-template-columns: 6fr 4fr;
			padding-inline: 2.5rem;
			gap: 3.75rem;
		}

		.roles {
			margin-top: 0.5rem;
			display: flex;
			gap: 0.5rem;
		}

		.hero img {
			aspect-ratio: 3 / 4;
			border-radius: 4.5rem;
			object-fit: cover;
		}
	}

	.section {
		display: grid;
		gap: 2rem;
	}

	.with-background {
		position: relative;
	}

	.with-background::before {
		--hero-bg: var(--bg-image-subtle-2);

		content: '';
		position: absolute;
		pointer-events: none;
		left: 50%;
		width: 100vw;
		aspect-ratio: calc(2.25 / var(--bg-scale));
		top: 0;
		transform: translateY(-75%) translateX(-50%);
		background:
			url('/assets/backgrounds/noise.png') top center/220px repeat,
			var(--hero-bg) center center / var(--bg-gradient-size) no-repeat,
			var(--gray-999);
		background-blend-mode: overlay, normal, normal, normal;
		mix-blend-mode: var(--bg-blend-mode);
		z-index: -1;
	}

	.with-background.bg-variant::before {
		--hero-bg: var(--bg-image-subtle-1);
	}

	.section-header {
		justify-self: center;
		text-align: center;
		max-width: 50ch;
		font-size: var(--text-md);
		color: var(--gray-300);
	}

	.section-header h3 {
		font-size: var(--text-2xl);
	}

	@media (min-width: 50em) {
		.section {
			grid-template-columns: repeat(4, 1fr);
			grid-template-areas: 'header header header header' 'gallery gallery gallery gallery';
			gap: 5rem;
		}

		.section.with-cta {
			grid-template-areas: 'header header header cta' 'gallery gallery gallery gallery';
		}

		.section-header {
			grid-area: header;
			font-size: var(--text-lg);
		}

		.section-header h3 {
			font-size: var(--text-4xl);
		}

		.with-cta .section-header {
			justify-self: flex-start;
			text-align: left;
		}

		.gallery {
			grid-area: gallery;
		}

		.cta {
			grid-area: cta;
		}
	}

	/* You may remove this if you deleted the old mention section */
	.answer-capsule {
		background: var(--gradient-accent-orange);
		border-radius: 1.5rem;
		padding: 2rem;
		text-align: center;
		margin: 2rem 0;
	}
	
	.answer-capsule h2 {
		color: var(--gray-0);
		font-size: var(--text-xl);
		margin-bottom: 1rem;
	}
	
	.answer-capsule p {
		color: var(--gray-100);
		font-size: var(--text-lg);
		line-height: 1.6;
		max-width: 60ch;
		margin: 0 auto;
	}

	.mention-card {
		display: flex;
		height: 7rem;
		justify-content: center;
		align-items: center;
		text-align: center;
		border: 1px solid var(--gray-800);
		border-radius: 1.5rem;
		color: var(--gray-300);
		background: var(--gradient-subtle);
		box-shadow: var(--shadow-sm);
	}

	@media (min-width: 50em) {
		.mention-card {
			border-radius: 1.5rem;
			height: 9.5rem;
		}
	}

	.blog-preview {
		margin-top: 3rem;
	}
	
	.blog-cards {
		display: grid;
		gap: 1.5rem;
		margin: 2rem 0;
	}
	
	@media (min-width: 50em) {
		.blog-cards {
			grid-template-columns: repeat(3, 1fr);
		}
	}
	
	.blog-card {
		background: var(--gradient-subtle);
		border: 1px solid var(--gray-800);
		border-radius: 1rem;
		padding: 1.5rem;
		transition: transform 0.2s ease;
	}
	
	.blog-card:hover {
		transform: translateY(-2px);
	}
	
	.blog-card h4 {
		margin-bottom: 0.5rem;
	}
	
	.blog-card h4 a {
		color: var(--gray-0);
		text-decoration: none;
		font-size: var(--text-lg);
		line-height: 1.3;
	}
	
	.blog-card h4 a:hover {
		color: var(--accent-regular);
	}
	
	.blog-card p {
		color: var(--gray-300);
		line-height: 1.6;
		font-size: var(--text-base);
	}
</style>
