---
import BaseLayout from '../layouts/BaseLayout.astro';
import ContactCTA from '../components/ContactCTA.astro';
import Hero from '../components/Hero.astro';
---

<BaseLayout title="About Minro | AI Calendar Assistant" description="Learn about Minro, the Y Combinator-backed AI calendar assistant that automates scheduling and email management for busy professionals.">
	<div class="stack gap-20">
		<main class="wrapper about">
			<Hero
				title="About Minro"
				tagline="The AI calendar assistant that transforms how busy professionals manage their time and coordination."
			>
				<img
					width="1553"
					height="873"
					src="/assets/yc-photo.png"
					alt="Minro team at Y Combinator"
					title="Minro - Y Combinator Backed AI Calendar Assistant"
				/>
			</Hero>

			<section>
				<h2 class="section-title">Our Mission</h2>
				<div class="content">
					<p>Minro transforms how busy professionals manage their calendars and coordination overhead. We're building an AI calendar assistant that understands natural language commands and automates the tedious parts of scheduling, email management, and time optimization.</p>

					<p>Backed by Y Combinator, our team is focused on creating technology that genuinely understands how people work. Instead of adding another app to your workflow, Minro becomes an invisible assistant that handles calendar logistics while you focus on meaningful work.</p>

					<p>Our AI-powered approach combines natural language processing, intelligent scheduling algorithms, and privacy-first architecture to deliver calendar automation that actually saves time. Users can simply say "Reschedule my morning meetings and give me focus time" and Minro handles the complex coordination automatically.</p>

					<p>We believe productivity tools should reduce cognitive overhead, not increase it. Every feature we build is designed to eliminate context switching, reduce email back-and-forth, and preserve the deep work time that creates real value in professional settings.</p>
				</div>
			</section>

			<section>
				<h2 class="section-title">How Minro Works</h2>
				<div class="content">
					<div class="education-item">
						<strong>Natural Language Interface</strong>
						<span class="edu-date">Voice & Text Commands</span>
						<p class="edu-desc">Simply tell Minro what you need: "Move my 3 PM meeting to tomorrow" or "Block focus time for the proposal."</p>
					</div>

					<div class="education-item">
						<strong>Intelligent Automation</strong>
						<span class="edu-date">AI-Powered Coordination</span>
						<p class="edu-desc">Minro automatically handles email responses, availability sharing, conflict resolution, and meeting preparation.</p>
					</div>

					<div class="education-item">
						<strong>Privacy-First Design</strong>
						<span class="edu-date">End-to-End Encryption</span>
						<p class="edu-desc">Your calendar data stays secure with industry-leading encryption and user-controlled privacy settings.</p>
					</div>
				</div>
			</section>

			<section>
				<h2 class="section-title">Key Features</h2>
				<div class="content">
					<div class="skills-grid">
						<div class="skill-category">
							<strong>Calendar Intelligence</strong>
							<span>Automated scheduling, conflict resolution, and time optimization</span>
						</div>
						<div class="skill-category">
							<strong>Email Automation</strong>
							<span>Context-aware responses, meeting coordination, and follow-up management</span>
						</div>
						<div class="skill-category">
							<strong>Integration</strong>
							<span>Works with Google Calendar, Outlook, Apple Calendar, and major email providers</span>
						</div>
						<div class="skill-category">
							<strong>Productivity Focus</strong>
							<span>Focus time protection, meeting preparation, and workflow optimization</span>
						</div>
					</div>
				</div>
			</section>
		</main>

		<ContactCTA />
	</div>
</BaseLayout>

<style>
	.about {
		display: flex;
		flex-direction: column;
		gap: 3.5rem;
	}

	img {
		margin-top: 1.5rem;
		border-radius: 1.5rem;
		box-shadow: var(--shadow-md);
		width: 100%;
		height: auto;
		object-fit: cover;
	}

	section {
		display: flex;
		flex-direction: column;
		gap: 0.5rem;
		color: var(--gray-200);
	}

	.section-title {
		grid-column-start: 1;
		font-size: var(--text-xl);
		color: var(--gray-0);
	}

	.content {
		grid-column: 2 / 4;
		font-size: var(--text-base);
		line-height: 1.7;
	}

	.content p {
		margin-bottom: 1rem;
	}

	.content :global(a) {
		text-decoration: 1px solid underline transparent;
		text-underline-offset: 0.25em;
		transition: text-decoration-color var(--theme-transition);
	}

	.content :global(a:hover),
	.content :global(a:focus) {
		text-decoration-color: currentColor;
	}

	/* Education styling */
	.education-item {
		margin-bottom: 1.5rem;
		padding-bottom: 1.5rem;
		border-bottom: 1px solid var(--gray-800);
	}

	.education-item:last-child {
		border-bottom: none;
		margin-bottom: 0;
		padding-bottom: 0;
	}

	.education-item strong {
		display: block;
		font-size: var(--text-lg);
		color: var(--gray-0);
		margin-bottom: 0.25rem;
	}

	.edu-date {
		display: block;
		font-size: var(--text-sm);
		color: var(--accent-regular);
		margin-bottom: 0.5rem;
	}

	.edu-desc {
		font-size: var(--text-base);
		color: var(--gray-300);
		margin: 0;
	}

	/* Skills grid styling */
	.skills-grid {
		display: grid;
		gap: 1.5rem;
		grid-template-columns: 1fr;
	}

	.skill-category {
		display: flex;
		flex-direction: column;
		gap: 0.5rem;
		padding: 1rem;
		background: var(--gradient-subtle);
		border-radius: 0.75rem;
		border: 1px solid var(--gray-800);
	}

	.skill-category strong {
		font-size: var(--text-base);
		color: var(--gray-0);
	}

	.skill-category span {
		font-size: var(--text-sm);
		color: var(--gray-300);
		line-height: 1.6;
	}

	@media (min-width: 50em) {
		.about {
			display: grid;
			grid-template-columns: 1fr 60% 1fr;
		}

		.about > :global(:first-child) {
			grid-column-start: 2;
		}

		section {
			display: contents;
		}

		.section-title {
			grid-column-start: 1;
			justify-self: start;
		}

		.content {
			font-size: var(--text-base);
			grid-column: 2 / 4;
		}

		.skills-grid {
			grid-template-columns: 1fr 1fr;
		}
	}
</style>
