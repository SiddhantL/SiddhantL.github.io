---
import BaseLayout from '../layouts/BaseLayout.astro';
import ContactCTA from '../components/ContactCTA.astro';
---

<BaseLayout title="About | Siddhant Lad" description="Learn more about Siddhant Lad.">
	<main class="wrapper">
		<section class="about-hero">
			<div class="about-intro">
				<h1>About</h1>
				<p class="subtitle">I'm Siddhant, co-founder of Minro (YC F25). I like building things that work and shipping them fast. Before Minro, I shipped 12 apps to 10K+ users, did ML research at UC San Diego, and built everything from IoT hardware to mobile apps.</p>
			</div>
			<img
				src="/assets/at-work.jpg"
				alt="Siddhant Lad"
				class="hero-image"
			/>
		</section>

		<div class="about-content">
			<div class="about-section">
				<h2>Now</h2>
				<div class="section-body">
					<p>Minro tells founders which users they're about to lose and what to do about it. We watch product usage, predict churn, and surface a daily briefing with ready-to-send outreach. The kind of tool I wish existed when I was running my own products.</p>
				</div>
			</div>

			<div class="about-section">
				<h2>Before</h2>
				<div class="section-body">
					<p>M.S. in Computer Science from UC San Diego, specializing in AI. Did my undergrad at NMIMS in Mumbai.</p>
					<p>Along the way I built a lot of things: Android apps, React Native apps, desktop apps, IoT systems, ML pipelines, 3D-printed hardware. Most of them shipped. Some of them people actually used.</p>
				</div>
			</div>
		</div>

		<ContactCTA />
	</main>
</BaseLayout>

<style>
	main {
		display: flex;
		flex-direction: column;
		gap: 3rem;
		padding-top: 4rem;
		padding-bottom: 0;
	}

	.about-hero {
		display: flex;
		flex-direction: column-reverse;
		align-items: center;
		gap: 2rem;
	}

	.about-intro h1 {
		font-size: var(--text-4xl);
		margin-bottom: 0.75rem;
	}

	.about-intro {
		text-align: center;
	}

	.subtitle {
		font-size: var(--text-md);
		color: var(--gray-400);
		line-height: 1.6;
	}

	.hero-image {
		width: 16rem;
		height: auto;
		border-radius: var(--radius-lg);
	}

	@media (min-width: 50em) {
		.about-hero {
			flex-direction: row;
			justify-content: space-between;
			align-items: flex-start;
			gap: 3rem;
		}

		.about-intro {
			text-align: left;
			flex: 1;
		}

		.hero-image {
			width: 18rem;
			flex-shrink: 0;
		}
	}

	.about-content {
		display: flex;
		flex-direction: column;
		gap: 3rem;
		max-width: 48rem;
	}

	.about-section h2 {
		font-size: var(--text-lg);
		margin-bottom: 1rem;
		padding-bottom: 0.75rem;
		border-bottom: 1px solid var(--gray-800);
	}

	.section-body p {
		color: var(--gray-300);
		line-height: 1.7;
		margin-bottom: 1rem;
	}

	.section-body p:last-child {
		margin-bottom: 0;
	}

	@media (min-width: 50em) {
		.about-hero h1 {
			font-size: var(--text-5xl);
		}
	}
</style>
