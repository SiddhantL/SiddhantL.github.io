---

<footer>
	<div class="wrapper footer-inner">
		<p class="copyright">&copy; {new Date().getFullYear()} Siddhant Lad</p>
		<div class="links">
			<a href="mailto:siddhantnlad@gmail.com">Email</a>
			<a href="https://github.com/SiddhantL" target="_blank" rel="noopener">GitHub</a>
			<a href="https://www.linkedin.com/in/sidlad" target="_blank" rel="noopener">LinkedIn</a>
			<a href="https://www.youtube.com/@siddhantlad" target="_blank" rel="noopener">YouTube</a>
		</div>
	</div>
</footer>

<style>
	footer {
		margin-top: auto;
		border-top: 1px solid var(--gray-800);
		padding: 2rem 0;
	}

	.footer-inner {
		display: flex;
		flex-direction: column;
		align-items: center;
		gap: 1rem;
	}

	.copyright {
		font-size: var(--text-sm);
		color: var(--gray-500);
	}

	.links {
		display: flex;
		gap: 1.5rem;
	}

	.links a {
		font-size: var(--text-sm);
		color: var(--gray-400);
		transition: color var(--transition);
	}

	.links a:hover {
		color: var(--gray-0);
	}

	@media (min-width: 50em) {
		.footer-inner {
			flex-direction: row;
			justify-content: space-between;
		}
	}
</style>
