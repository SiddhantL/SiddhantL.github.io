---
interface Props {
	variant?: 'offset' | 'small';
}

const { variant } = Astro.props;
---

<ul class:list={['grid', variant]}>
	<slot />
</ul>

<style>
	.grid {
		display: grid;
		gap: 1.5rem;
		list-style: none;
		padding: 0;
		grid-template-columns: 1fr;
	}

	@media (min-width: 40em) {
		.grid {
			grid-template-columns: 1fr 1fr;
		}
	}

	@media (min-width: 64em) {
		.grid.offset {
			grid-template-columns: 1fr 1fr;
			gap: 2rem;
		}

		.grid.small {
			grid-template-columns: repeat(3, 1fr);
		}
	}
</style>
